rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function getHouseholdId() {
      return get(/databases/$(database)/documents/members/$(request.auth.uid)).data.householdId;
    }

    match /members/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
    }

    match /households/{householdId} {
      allow read: if request.auth != null
        && exists(/databases/$(database)/documents/members/$(request.auth.uid))
        && getHouseholdId() == householdId;
    }

    match /varieties/{docId} {
      allow read: if request.auth != null && resource.data.householdId == getHouseholdId();
      allow create: if request.auth != null && request.resource.data.householdId == getHouseholdId();
      allow update, delete: if request.auth != null && resource.data.householdId == getHouseholdId();
    }

    match /beds/{docId} {
      allow read: if request.auth != null && resource.data.householdId == getHouseholdId();
      allow create: if request.auth != null && request.resource.data.householdId == getHouseholdId();
      allow update, delete: if request.auth != null && resource.data.householdId == getHouseholdId();
    }

    match /plantings/{docId} {
      allow read: if request.auth != null && resource.data.householdId == getHouseholdId();
      allow create: if request.auth != null && request.resource.data.householdId == getHouseholdId();
      allow update, delete: if request.auth != null && resource.data.householdId == getHouseholdId();
    }

    match /tasks/{docId} {
      allow read: if request.auth != null && resource.data.householdId == getHouseholdId();
      allow create: if request.auth != null && request.resource.data.householdId == getHouseholdId();
      allow update, delete: if request.auth != null && resource.data.householdId == getHouseholdId();
    }

    match /taskTemplates/{docId} {
      allow read: if request.auth != null && resource.data.householdId == getHouseholdId();
      allow create: if request.auth != null && request.resource.data.householdId == getHouseholdId();
      allow update, delete: if request.auth != null && resource.data.householdId == getHouseholdId();
    }

    match /harvests/{docId} {
      allow read: if request.auth != null && resource.data.householdId == getHouseholdId();
      allow create: if request.auth != null && request.resource.data.householdId == getHouseholdId();
      allow update, delete: if request.auth != null && resource.data.householdId == getHouseholdId();
    }

    match /alerts/{docId} {
      allow read: if request.auth != null && resource.data.householdId == getHouseholdId();
      allow create: if request.auth != null && request.resource.data.householdId == getHouseholdId();
    }

    match /weather/{docId} {
      allow read: if request.auth != null;
    }

    match /fcmTokens/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
